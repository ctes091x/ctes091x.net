---
import ReciprocalLinkCard from "./ReciprocalLinkCard.astro";

const links = [
  { name: "しおり🔖", url: "https://shiori-02-14.github.io/Homepage/", iconId: "x/shiori_02_14_", desc: "早くAndroidユーザにもNEXUS使わせてください" },
  { name: "柴犬被り", url: "https://memo.shibadogcap.com/", iconId: "github/shibadogcap", desc: "UEC25あつまれ〜の創設者。徒歩するぞ！！" },
  { name: "トラマト", url: "https://toramutton.me/", iconId: "x/ToraMutton", desc: "ユーモアに溢れる超有能記事をいつもありがとう" },
  { name: "ThunFasky", url: "https://thunfasky.com/", iconId: "x/ThunFasky", desc: "お洒落すぎないか？？？" },
  { name: "こっとん", url: "https://cotton7.me/", iconId: "x/cotton_tech7", desc: "レートよこせ〜" },
  { name: "コメネズミ", url: "https://komenezumi.net/", iconId: "x/komenezumi1006", desc: "高校同期。つよつよ自宅鯖いいね" }
];
---

<ul>
  {links.map(link => (
      <ReciprocalLinkCard name={link.name} url={link.url} iconId={link.iconId} desc={link.desc} />
  ))}
</ul>

